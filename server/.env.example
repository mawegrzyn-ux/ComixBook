# ── Required ──────────────────────────────────────────────────
SD_HOST=http://localhost:7860
API_KEY=change-me-to-something-strong

# ── Paths (defaults work on RunPod) ──────────────────────────
KOHYA_DIR=/workspace/kohya_ss
WEBUI_DIR=/workspace/stable-diffusion-webui
GALLERY_DIR=/workspace/gallery

# ── Idle auto-shutdown ────────────────────────────────────────
# Set IDLE_MINUTES=0 to disable
IDLE_MINUTES=30
RUNPOD_API_KEY=
RUNPOD_POD_ID=

# ── Optional ──────────────────────────────────────────────────
PORT=3000
